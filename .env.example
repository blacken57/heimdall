# ── Services ──────────────────────────────────────────────────────────────
# Add as many numbered pairs as you need; scanning stops at the first gap.
SERVICE_1_NAME=My Website
SERVICE_1_URL=https://example.com
SERVICE_2_NAME=Raspberry Pi
SERVICE_2_URL=http://raspberrypi.local:8080/health

# ── Polling ────────────────────────────────────────────────────────────────
POLL_INTERVAL=60          # seconds between checks (default: 60)
HTTP_TIMEOUT=10           # HTTP request timeout in seconds (default: 10)

# ── Storage ────────────────────────────────────────────────────────────────
DB_PATH=/data/heimdall.db # SQLite path (default: ./heimdall.db)
DATA_RETENTION_DAYS=90    # days to keep check history (default: 90)

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8080                 # web UI port (default: 8080)

# ── Basic Auth ─────────────────────────────────────────────────────────────
# Both must be set to enable auth; omit both to run open (no login required).
HEIMDALL_USER=admin
HEIMDALL_PASSWORD=changeme
